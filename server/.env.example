# ===== Server =====
NODE_ENV=development
PORT=5000

# Allowed CORS origin (the Vite dev server). Comma-separated for multiple.
CLIENT_URL=http://localhost:5173

# ===== Database =====
# Local MongoDB (default). Change to your Atlas URI if using cloud.
MONGODB_URI=mongodb://127.0.0.1:27017/classic_express_erp

# ===== JWT =====
# Use long, random strings in production. `openssl rand -hex 32` (or any secure generator).
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret_string
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Cookie security: set SECURE_COOKIES=true in production (HTTPS only).
SECURE_COOKIES=false

# ===== Seed (default System Admin) =====
# Created on first run of `npm run seed` if it doesn't already exist.
SEED_ADMIN_NAME=System Administrator
SEED_ADMIN_EMAIL=admin@classicexpress.com
SEED_ADMIN_PASSWORD=Admin@Classic2025
SEED_ADMIN_PHONE=+919000000000

# ===== Cloudinary (optional in Phase 1; required for file uploads in Phase 4) =====
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
